# 平台侧登记的 Agent 唯一标识。
# 建议格式: agent-<project>-<env>，例如 agent-project-x-prod。
AGENT_ID=agent-project-x

# Agent 绑定的平台环境 ID。
# 首次注册时建议留空；在平台页面认领 Agent 后，Agent 会通过心跳同步绑定关系。
# 如果重启后希望减少一次同步等待，也可以填写已认领的环境 ID。
AGENT_ENVIRONMENT_ID=

# Agent 可出站访问的平台地址，必须包含协议和端口。
# 研发测试可填 http://<platform-host>:8080，正式建议使用可访问的 HTTPS 地址。
PLATFORM_URL=http://platform.example.com:8080

# Agent 调用平台 API 时使用的运行令牌。
# 首次注册时可留空，平台会通过 AGENT_REGISTER_TOKEN 换取运行令牌；重启前建议保存平台返回的 AGENT_TOKEN。
AGENT_TOKEN=

# Agent 首次注册令牌。
# 在平台 Agent 管理页面生成后填写；使用一次后失效。
AGENT_REGISTER_TOKEN=

# Agent 执行模式。
# V1 研发阶段默认使用 remote-probe，只做真实远程资源探测，不模拟发布/部署成功。
AGENT_MODE=remote-probe

# Agent 本地健康检查端口，仅供本机或宿主机探活使用。
# 默认 18080；若宿主机已有冲突端口，可改为其他未占用端口。
AGENT_HEALTH_PORT=18080

# 轮询平台租约接口的间隔秒数。
# 值越小领取任务越快，但请求更频繁；研发阶段建议保持 5 秒。
AGENT_POLL_INTERVAL_SECONDS=5

# Agent 向平台发送心跳的间隔秒数。
# 研发阶段建议 15 秒；过大将延迟平台侧在线状态刷新。
AGENT_HEARTBEAT_INTERVAL_SECONDS=15

# Agent 请求平台 API 的超时时间，单位秒。
# 需要覆盖普通接口网络抖动，但不宜过长；研发阶段建议 10 秒。
AGENT_HTTP_TIMEOUT_SECONDS=10

# Agent 可并发执行的任务数。
# V1 当前只支持 1，禁止修改为其他值。
AGENT_MAX_TASKS=1

# Agent 能力列表，逗号分隔。
# 当前用于平台侧展示和探测任务匹配。
AGENT_CAPABILITIES=remote-probe,kubectl,http-check

# Kubernetes 探测配置。
# Agent 机器需要已安装 kubectl；该 kubeconfig 必须能访问环境绑定的 namespace。
AGENT_KUBECONFIG=

# Harbor 探测配置。
# 用于验证环境绑定的 Harbor project 是否真实存在。
AGENT_HARBOR_URL=
AGENT_HARBOR_USERNAME=
AGENT_HARBOR_PASSWORD=
AGENT_HARBOR_INSECURE_SKIP_TLS_VERIFY=false
