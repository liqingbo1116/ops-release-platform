# 平台侧登记的 Agent 唯一标识。首次注册建议直接使用平台页面生成的值。
# 如需手工填写，建议格式: agent-<project>-<product>，例如 agent-project-x-prod。
AGENT_ID=agent-project-x

# Agent 绑定的平台环境 ID。
# 首次注册时建议留空；在平台页面认领 Agent 后，Agent 会通过心跳同步绑定关系。
# 如果重启后希望减少一次同步等待，也可以填写已认领的环境 ID。
AGENT_ENVIRONMENT_ID=

# Agent 可出站访问的平台后端 API 地址，必须包含协议和端口。
# 研发测试可填 http://<platform-host>:8080，正式建议使用可访问的 HTTPS 地址。
# 如果页面生成的是 127.0.0.1 或 localhost，部署到项目环境前必须改成项目环境机器可访问的平台地址。
PLATFORM_URL=http://platform.example.com:8080

# Agent 调用平台 API 时使用的运行令牌。
# 首次注册时可留空；使用 -f 配置文件启动时，注册成功后 Agent 会自动写回平台签发的运行令牌。
AGENT_TOKEN=

# Agent 首次注册令牌。在平台 Agent 管理页面生成后填写；使用一次后失效。
# 首次启动最少需要配置 PLATFORM_URL 和 AGENT_REGISTER_TOKEN。
AGENT_REGISTER_TOKEN=

# Agent 执行模式。
# V1 研发阶段默认使用 remote-probe，只做真实远程资源探测，不模拟发布/部署成功。
AGENT_MODE=remote-probe

# Agent 本地健康检查端口，仅供本机或宿主机探活使用。
# 默认 18080；若宿主机已有冲突端口，可改为其他未占用端口。
AGENT_HEALTH_PORT=18080

# 轮询平台租约接口的间隔秒数。
# 值越小领取任务越快，但请求更频繁；研发阶段建议保持 5 秒。
AGENT_POLL_INTERVAL_SECONDS=5

# Agent 向平台发送心跳的间隔秒数。
# 研发阶段建议 15 秒；过大将延迟平台侧在线状态刷新。
AGENT_HEARTBEAT_INTERVAL_SECONDS=15

# Agent 请求平台 API 的超时时间，单位秒。
# 需要覆盖普通接口网络抖动，但不宜过长；研发阶段建议 10 秒。
AGENT_HTTP_TIMEOUT_SECONDS=10

# Agent 可并发执行的任务数。
# V1 当前只支持 1，禁止修改为其他值。
AGENT_MAX_TASKS=1

# Agent 能力列表，逗号分隔。
# 当前用于平台侧展示和探测任务匹配。
AGENT_CAPABILITIES=remote-probe,k8s-api,http-check

# 远程 Kubernetes 连接配置。Agent 通过 Kubernetes API 读取远程集群资源并上报平台。
# namespace 与产品的对应关系在平台产品配置中维护，不在 Agent 配置中指定。
# 不要求 Agent 机器安装 kubectl；该 kubeconfig 需要能读取远程产品运行所需 namespace 和 workload。
AGENT_KUBECONFIG=

# 远程 Harbor 连接配置。Agent 会读取远程 Harbor project、镜像和 tag 并上报平台。
# Harbor project 与产品的对应关系在平台产品配置中维护，不在 Agent 配置中指定。
AGENT_HARBOR_URL=
AGENT_HARBOR_USERNAME=
AGENT_HARBOR_PASSWORD=
AGENT_HARBOR_INSECURE_SKIP_TLS_VERIFY=false
